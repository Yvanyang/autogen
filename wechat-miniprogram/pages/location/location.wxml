<!--pages/location/location.wxml-->
<view class="container">
  <view class="search-bar">
    <view class="search-input-wrapper">
      <image class="search-icon" src="/images/search.png" mode="aspectFit"></image>
      <input 
        class="search-input" 
        value="{{searchValue}}" 
        bindinput="onSearchInput" 
        placeholder="搜索位置" 
        confirm-type="search"
      ></input>
      <view class="clear-button" bindtap="clearSearch" wx:if="{{searchValue.length > 0}}">
        <image class="clear-icon" src="/images/clear.png" mode="aspectFit"></image>
      </view>
    </view>
    <view class="cancel-button" bindtap="cancelSelection">取消</view>
  </view>
  
  <view class="search-results" wx:if="{{showSearchResults}}">
    <view class="loading" wx:if="{{isSearching}}">
      <view class="loading-spinner"></view>
      <text class="loading-text">搜索中...</text>
    </view>
    
    <view class="result-item" 
      wx:for="{{searchResults}}" 
      wx:key="id" 
      bindtap="selectLocation" 
      data-index="{{index}}">
      <view class="result-icon">
        <image class="location-icon" src="/images/location-pin.png" mode="aspectFit"></image>
      </view>
      <view class="result-info">
        <view class="result-name">{{item.name}}</view>
        <view class="result-address">{{item.address}}</view>
      </view>
    </view>
    
    <view class="empty-results" wx:if="{{searchResults.length === 0 && !isSearching}}">
      <text>没有找到相关位置</text>
    </view>
  </view>
  
  <view class="map-container" wx:if="{{!showSearchResults}}">
    <map
      id="locationMap"
      latitude="{{latitude}}"
      longitude="{{longitude}}"
      scale="{{scale}}"
      markers="{{markers}}"
      show-location="true"
      enable-rotate="true"
      enable-overlooking="true"
      enable-3D="true"
      bindregionchange="onRegionChange"
      style="width: 100%; height: 100%;"
    ></map>
    
    <view class="map-controls">
      <view class="control-button" bindtap="getCurrentLocation">
        <image class="control-icon" src="/images/current-location.png" mode="aspectFit"></image>
      </view>
    </view>
    
    <view class="center-marker">
      <image class="marker-icon" src="/images/center-marker.png" mode="aspectFit"></image>
    </view>
  </view>
  
  <view class="location-info" wx:if="{{selectedLocation && !showSearchResults}}">
    <view class="location-details">
      <view class="location-name">{{selectedLocation.name}}</view>
      <view class="location-address">{{selectedLocation.address}}</view>
    </view>
    <view class="confirm-button" bindtap="confirmLocation">确定</view>
  </view>
</view>
