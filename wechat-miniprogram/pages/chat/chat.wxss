/* pages/chat/chat.wxss */
.container {
  height: 100%;
  display: flex;
  flex-direction: column;
  background-color: #f1f1f1;
}

.message-list {
  flex: 1;
  padding: 16px;
  box-sizing: border-box;
}

.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16px;
  color: #999;
}

.loading-spinner {
  width: 20px;
  height: 20px;
  margin-right: 8px;
}

.loading-text {
  font-size: 14px;
}

.message-item {
  display: flex;
  margin-bottom: 16px;
}

.message-item.self {
  flex-direction: row-reverse;
}

.avatar {
  width: 40px;
  height: 40px;
  border-radius: 4px;
  margin: 0 12px;
}

.message-content {
  max-width: 70%;
  display: flex;
  flex-direction: column;
}

.message-item.self .message-content {
  align-items: flex-end;
}

.message-item.other .message-content {
  align-items: flex-start;
}

.message-bubble {
  border-radius: 4px;
  padding: 10px 12px;
  margin-bottom: 4px;
  word-break: break-all;
}

.message-item.self .message-bubble {
  background-color: #07C160;
  color: #fff;
  border-top-right-radius: 0;
}

.message-item.other .message-bubble {
  background-color: #fff;
  color: #333;
  border-top-left-radius: 0;
}

.message-bubble.image {
  padding: 4px;
  background-color: transparent;
}

.message-bubble.image image {
  max-width: 200px;
  border-radius: 4px;
}

.message-bubble.location {
  padding: 8px;
  width: 200px;
}

.location-name {
  font-weight: 500;
  margin-bottom: 4px;
}

.location-address {
  font-size: 12px;
  color: #666;
  margin-bottom: 8px;
}

.location-map {
  width: 100%;
  height: 120px;
  border-radius: 4px;
  overflow: hidden;
}

.message-status {
  display: flex;
  align-items: center;
  margin-top: 2px;
}

.status-text {
  font-size: 12px;
  color: #999;
}

.status-icon {
  width: 16px;
  height: 16px;
}

.message-time {
  font-size: 12px;
  color: #999;
  margin-top: 2px;
}

.input-area {
  display: flex;
  align-items: center;
  padding: 10px 16px;
  background-color: #fff;
  border-top: 1px solid #eee;
}

.input-actions {
  padding: 0 8px;
}

.action-icon {
  width: 28px;
  height: 28px;
}

.input-box {
  flex: 1;
  background-color: #f5f5f5;
  border-radius: 4px;
  padding: 8px 12px;
  margin: 0 8px;
}

.input {
  width: 100%;
  height: 20px;
  line-height: 20px;
  font-size: 16px;
}

.send-button {
  background-color: #07C160;
  color: #fff;
  padding: 6px 12px;
  border-radius: 4px;
  font-size: 14px;
}

.image-picker-container, .location-picker-container {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  flex-direction: column;
}

.image-picker-mask, .location-picker-mask {
  flex: 1;
  background-color: rgba(0, 0, 0, 0.5);
}

.image-picker, .location-picker {
  background-color: #fff;
  height: 300px;
}
